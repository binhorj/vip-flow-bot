# Servidor
PORT=3000
NODE_ENV=development

# Banco de Dados
DB_PATH=./bot.db

# JWT
JWT_SECRET=sua_chave_secreta_super_segura_aqui_mude_isso
JWT_EXPIRY=24h

# Telegram - Produção
TELEGRAM_BOT_TOKEN=seu_token_do_bot_aqui
TELEGRAM_PRODUCTION_CHAT_ID=seu_chat_id_de_producao_aqui

# Telegram - Teste (IMPORTANTE: criar grupo privado para testar)
TELEGRAM_TEST_CHAT_ID=seu_chat_id_de_teste_aqui

# TEST MODE (OBRIGATÓRIO: deixar true até validar tudo)
TEST_MODE=true

# Admin padrão
ADMIN_EMAIL=admin@vipflow.com
ADMIN_PASSWORD=123456
