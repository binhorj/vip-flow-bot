<!-- BACKUP - dashboard.html original antes do redesign -->
<!-- Data: 2026-05-21 -->
<!-- Etapa 1: Redesign Profissional -->

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>VIP FLOW BOT - Dashboard</title>
  <link rel="stylesheet" href="../css/global.css">
</head>
<body>
  <!-- Sidebar -->
  <div class="sidebar">
    <div class="sidebar-header">
      <div class="logo">🔥 VIP FLOW</div>
    </div>

    <nav class="nav">
      <a class="nav-item active" data-page="dashboard" href="/pages/dashboard.html">
        <span class="nav-icon">📊</span>
        <span>Dashboard</span>
      </a>
      <a class="nav-item" data-page="photos" href="/pages/photos.html">
        <span class="nav-icon">📷</span>
        <span>Fotos</span>
      </a>
      <a class="nav-item" data-page="campaigns" href="/pages/campaigns.html">
        <span class="nav-icon">📢</span>
        <span>Campanhas</span>
      </a>
      <a class="nav-item" data-page="history" href="/pages/history.html">
        <span class="nav-icon">📜</span>
        <span>Histórico</span>
      </a>
      <a class="nav-item" data-page="settings" href="/pages/settings.html">
        <span class="nav-icon">⚙️</span>
        <span>Configurações</span>
      </a>
    </nav>

    <div class="sidebar-footer">
      <div class="user-info">
        <strong>Carregando...</strong>
      </div>
      <button class="btn btn-secondary btn-small" onclick="logout()" style="width: 100%;">
        🚪 Sair
      </button>
    </div>
  </div>

  <!-- Main Content -->
  <div class="main">
    <div id="messageContainer"></div>

    <div style="margin-bottom: 30px;">
      <h1>📊 Dashboard</h1>
      <p style="color: #6b7280; margin-top: 5px;">Bem-vindo ao VIP FLOW BOT</p>
    </div>

    <!-- Métricas -->
    <div class="metrics-grid">
      <div class="metric-card">
        <div class="metric-label">Campanhas Ativas</div>
        <div class="metric-value" id="metricCampaigns">-</div>
        <div class="metric-change" id="metricCampaignsChange"></div>
      </div>

      <div class="metric-card" style="border-left-color: #10b981;">
        <div class="metric-label">Agendamentos Pendentes</div>
        <div class="metric-value" id="metricSchedules" style="color: #10b981;">-</div>
        <div class="metric-change" id="metricSchedulesChange"></div>
      </div>

      <div class="metric-card" style="border-left-color: #f59e0b;">
        <div class="metric-label">Enviados Hoje</div>
        <div class="metric-value" id="metricSent" style="color: #f59e0b;">-</div>
        <div class="metric-change" id="metricSentChange"></div>
      </div>

      <div class="metric-card" style="border-left-color: #ef4444;">
        <div class="metric-label">Erros Recentes</div>
        <div class="metric-value" id="metricErrors" style="color: #ef4444;">-</div>
        <div class="metric-change" id="metricErrorsChange"></div>
      </div>
    </div>

    <!-- Cards de Ação -->
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; margin-bottom: 30px;">
      <div class="card">
        <div class="card-header">
          <div class="card-title">📷 Gerenciar Fotos</div>
        </div>
        <div class="card-body">
          <p style="color: #6b7280; margin-bottom: 15px;">Upload e organização de imagens para campanhas</p>
        </div>
        <div class="card-footer">
          <a href="photos.html" class="btn btn-primary">Acessar</a>
        </div>
      </div>

      <div class="card">
        <div class="card-header">
          <div class="card-title">📢 Nova Campanha</div>
        </div>
        <div class="card-body">
          <p style="color: #6b7280; margin-bottom: 15px;">Criar e agendar campanhas de marketing</p>
        </div>
        <div class="card-footer">
          <a href="campaigns.html" class="btn btn-primary">Criar</a>
        </div>
      </div>

      <div class="card">
        <div class="card-header">
          <div class="card-title">📜 Ver Histórico</div>
        </div>
        <div class="card-body">
          <p style="color: #6b7280; margin-bottom: 15px;">Análise de postagens e performance</p>
        </div>
        <div class="card-footer">
          <a href="history.html" class="btn btn-primary">Visualizar</a>
        </div>
      </div>
    </div>

    <!-- Últimas Postagens -->
    <div class="card">
      <div class="card-header">
        <div class="card-title">⏱️ Próximos Agendamentos</div>
      </div>
      <div class="card-body">
        <div id="schedulesContainer" style="min-height: 200px; display: flex; align-items: center; justify-content: center; color: #6b7280;">
          Carregando...
        </div>
      </div>
    </div>
  </div>

  <script src="../js/helpers.js"></script>
  <script>
    // Inicializar página
    initPage('dashboard');

    // Carregar dados
    async function loadMetrics() {
      try {
        // Campanhas
        const campaigns = await get('/api/campaigns');
        const activeCampaigns = campaigns.campaigns?.filter(c => c.status === 'active').length || 0;
        $('#metricCampaigns').textContent = activeCampaigns;

        // Agendamentos pendentes
        const schedules = await get('/api/schedules');
        const pendingSchedules = schedules.schedules?.filter(s => !s.is_sent).length || 0;
        $('#metricSchedules').textContent = pendingSchedules;

        // Métricas gerais
        const metrics = await get('/api/metrics/stats');
        $('#metricSent').textContent = metrics.stats?.sent_today || 0;
        $('#metricErrors').textContent = metrics.stats?.errors_today || 0;

        // Próximas agendamentos
        loadSchedules();
      } catch (error) {
        console.error('Erro ao carregar métricas:', error);
        // Fallback: mostrar 0 se houver erro
        $('#metricCampaigns').textContent = '0';
        $('#metricSchedules').textContent = '0';
        $('#metricSent').textContent = '0';
        $('#metricErrors').textContent = '0';
      }
    }

    async function loadSchedules() {
      try {
        const data = await get('/api/schedules');
        const schedules = data.schedules || [];
        const pending = schedules.filter(s => !s.is_sent).slice(0, 5);

        const container = $('#schedulesContainer');

        if (pending.length === 0) {
          container.innerHTML = '<p style="color: #6b7280; text-align: center;">Nenhum agendamento pendente</p>';
          return;
        }

        let html = '<table class="table"><thead><tr><th>Campanha</th><th>Agendado para</th><th>Status</th></tr></thead><tbody>';

        pending.forEach(s => {
          const date = formatDate(s.scheduled_at);
          html += `
            <tr>
              <td>${truncate(s.campaign_name || 'Sem nome', 30)}</td>
              <td>${date}</td>
              <td>${getStatusBadge('pending')}</td>
            </tr>
          `;
        });

        html += '</tbody></table>';
        container.innerHTML = html;
      } catch (error) {
        console.error('Erro ao carregar agendamentos:', error);
      }
    }

    // Recarregar a cada 30 segundos
    loadMetrics();
    setInterval(loadMetrics, 30000);
  </script>
</body>
</html>
